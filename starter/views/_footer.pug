footer.footer  
    button#search-button Calculate Distance

    // 汇率换算器部分
    <!-- 触发按钮 -->
    <button id="show-converter">Show Currency Converter</button>
    <!-- 货币换算器部分，初始隐藏 -->
    <div class="currency-converter" style="display: none;">
    .currency-converter
        h3 Currency Converter
        .input-group
            input#amount(type='number', placeholder='Enter amount')
            select#from-currency
                option(value='USD') USD
                option(value='EUR') EUR
                option(value='CNY') CNY
            select#to-currency
                option(value='EUR') EUR
                option(value='CNY') CNY
                option(value='USD') USD
        button#convert Convert
        .result#result
    </div>
    
    ul.footer__nav 
        li:a(href='#') About us
        li:a(href='#') Download apps
        li:a(href='#') Become a guide
        li:a(href='#') Careers 
        li:a(href='#') Contact 
    p.footer__copyright &copy; by Liming Huang. All rights reserved

    // 引入exchange.js
    script(src='/js/exchange.js')
    script(src='/js/search.js')
